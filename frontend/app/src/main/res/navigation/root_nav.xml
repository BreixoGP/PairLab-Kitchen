<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/launcherFragment">

    <fragment
        android:id="@+id/launcherFragment"
        android:name="com.example.fpappfront.ui.launcher.LauncherFragment">

        <action
            android:id="@+id/action_launcher_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/launcherFragment"
            app:popUpToInclusive="true"/>

        <action
            android:id="@+id/action_launcher_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/launcherFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.fpappfront.ui.auth.login.LoginFragment">

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.fpappfront.ui.auth.register.RegisterFragment">

        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.fpappfront.ui.home.HomeFragment" />

    <fragment
        android:id="@+id/userFragment"
        android:name="com.example.fpappfront.ui.user.UserFragment" />
    <action
        android:id="@+id/action_user_to_login"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/userFragment"
        app:popUpToInclusive="true"/>
</navigation>