<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivComboIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="@string/app_logo"
            android:src="@drawable/bombillatrans"
            app:tint="?attr/colorPrimary"
            android:padding="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvCombo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/ivComboIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivComboIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivComboIcon"
            tools:text="Tomato + Basil + Mozzarella"/>

        <LinearLayout
            android:id="@+id/scoreContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:drawable/toast_frame"
            android:backgroundTint="?attr/colorPrimaryContainer"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="@id/tvCombo"
            app:layout_constraintTop_toBottomOf="@id/ivComboIcon"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimaryContainer"
                tools:text="9.8"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvHintAi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/scoreContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/scoreContainer"
            app:layout_constraintBottom_toBottomOf="@id/scoreContainer"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>